# ===== CallIQ configuration =====
# Copy to .env and fill in. With DEMO_MODE=true the app runs fully on synthetic data
# and needs NO keys at all.

# Core
JWT_SECRET=change-me-to-a-long-random-string
POSTGRES_PASSWORD=change-me-too
WEB_PORT=8080
DEMO_MODE=true

# --- Go-live keys (set DEMO_MODE=false once these are filled) ---

# Deepgram (transcription) — console.deepgram.com
DEEPGRAM_API_KEY=

# Anthropic Claude (analysis) — console.anthropic.com
ANTHROPIC_API_KEY=

# RingCentral — developers.ringcentral.com (create a Server/No-UI app with
# Read Call Log + Read Call Recording + Webhook Subscriptions permissions, JWT auth)
RINGCENTRAL_SERVER_URL=https://platform.ringcentral.com
RINGCENTRAL_CLIENT_ID=
RINGCENTRAL_CLIENT_SECRET=
RINGCENTRAL_JWT=

# GDPR retention: auto-delete calls older than N days (0 = keep forever)
RETENTION_DAYS=0

# ===== CompanyIQ — in-call company intelligence =====
# Every source below is OPTIONAL. Leave a key blank and that source shows a clean
# "not configured" state in the panel; the rest still works. Companies House is free
# and is the recommended first key to add.

# Optional shared cache (otherwise an in-process cache is used). e.g. redis://localhost:6379/0
REDIS_URL=

# Companies House — free. Register at developer.company-information.service.gov.uk
CH_API_KEY=

# Apollo.io — decision-maker enrichment (app.apollo.io → Settings → API)
APOLLO_API_KEY=

# Hunter.io — email verification (hunter.io → API)
HUNTER_API_KEY=

# Lemlist — outreach/sequence status (app.lemlist.com → Settings → Integrations)
LEMLIST_API_KEY=

# Google Places (New) — branch locations (console.cloud.google.com → Places API)
GOOGLE_PLACES_KEY=

# Sales Tracker — order history shown in CompanyIQ (replaces the old NetSuite feed).
# Excel workbook, one tab per month ("May 26 - Total LB MTD" etc). Set SALES_TRACKER_URL
# to an "anyone with the link" SharePoint share — the app converts it to a guestaccess
# download (no auth) and refreshes every 24h. (SALES_TRACKER_SHARE_URL = Graph fetch alt;
# SALES_TRACKER_XLSX = local file fallback.)
SALES_TRACKER_URL=
SALES_TRACKER_SHARE_URL=
SALES_TRACKER_XLSX=

# SalesIQ — the other three trackers (anonymous "anyone with the link" SharePoint shares,
# same pattern as SALES_TRACKER_URL). Blank => that SalesIQ section shows "not connected".
LEAD_TRACKER_URL=
ACTIVITY_TRACKER_URL=
HOLIDAY_TRACKER_URL=

# Master companies directory — a Google Sheet read via a service account (6th source).
# Share the sheet with the service-account email. Provide creds via EITHER a JSON key
# file path OR (recommended for Railway) the whole JSON in GOOGLE_SERVICE_ACCOUNT_JSON.
MASTER_SHEET_ID=
MASTER_SHEET_TAB=Companies
GOOGLE_SERVICE_ACCOUNT_FILE=config/google-service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON=
